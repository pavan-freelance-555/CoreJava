Here’s a production-ready stored procedure version of the zero-downtime, partitioned, batch + delta + parallel migration for Azure SQL. You can just call it with parameters like source table, partition column, batch size, and parallelism.
Stored Procedure: usp_PartitionedMigration
SQL
Copy code
CREATE OR ALTER PROCEDURE dbo.usp_PartitionedMigration
    @SourceTable SYSNAME,
    @PartitionColumn SYSNAME,
    @BatchSize INT = 100000,
    @Parallelism INT = 4
AS
BEGIN
    SET NOCOUNT ON;

    DECLARE 
        @ShadowTable SYSNAME = @SourceTable + '_shadow',
        @StageTable SYSNAME = @SourceTable + '_stage',
        @BoundaryList NVARCHAR(MAX),
        @PF_SQL NVARCHAR(MAX),
        @IDX_SQL NVARCHAR(MAX),
        @DeltaRows INT = 1,
        @PartitionDate DATE,
        @PartitionNum INT,
        @SwitchSQL NVARCHAR(MAX);

    ----------------------------------------------------------------
    -- STEP 1: Get distinct partition boundaries dynamically
    ----------------------------------------------------------------
    SELECT @BoundaryList = STRING_AGG('''' + CONVERT(VARCHAR(10), CAST(' + QUOTENAME(@PartitionColumn) + ' AS DATE), 120) + '''', ',')
    FROM (SELECT DISTINCT CAST(' + QUOTENAME(@PartitionColumn) + ' AS DATE) FROM ' + @SourceTable + ') A;

    ----------------------------------------------------------------
    -- STEP 2: Create partition function
    ----------------------------------------------------------------
    SET @PF_SQL = 'CREATE PARTITION FUNCTION pf_' + @ShadowTable + '(DATE)
                   AS RANGE RIGHT FOR VALUES (' + @BoundaryList + ')';
    PRINT @PF_SQL;
    EXEC(@PF_SQL);

    ----------------------------------------------------------------
    -- STEP 3: Create partition scheme
    ----------------------------------------------------------------
    EXEC('CREATE PARTITION SCHEME ps_' + @ShadowTable + '
          AS PARTITION pf_' + @ShadowTable + '
          ALL TO ([PRIMARY])');

    ----------------------------------------------------------------
    -- STEP 4: Create shadow table dynamically
    ----------------------------------------------------------------
    EXEC('SELECT TOP 0 * INTO ' + @ShadowTable + ' FROM ' + @SourceTable);

    -- Create clustered partitioned index
    EXEC('CREATE CLUSTERED INDEX CI_' + @ShadowTable + '
          ON ' + @ShadowTable + '(' + @PartitionColumn + ', report_id)
          ON ps_' + @ShadowTable + '(' + @PartitionColumn + ')');

    ----------------------------------------------------------------
    -- STEP 5: Create stage table dynamically
    ----------------------------------------------------------------
    EXEC('SELECT TOP 0 * INTO ' + @StageTable + ' FROM ' + @SourceTable);
    EXEC('CREATE CLUSTERED INDEX CI_stage ON ' + @StageTable + '(' + @PartitionColumn + ', report_id)');

    ----------------------------------------------------------------
    -- STEP 6: Parallel partition load
    ----------------------------------------------------------------
    DECLARE @PartitionList TABLE (PartitionDate DATE, Status INT DEFAULT 0);
    INSERT INTO @PartitionList (PartitionDate)
    SELECT DISTINCT CAST(' + QUOTENAME(@PartitionColumn) + ' AS DATE) FROM ' + @SourceTable;

    WHILE EXISTS(SELECT 1 FROM @PartitionList WHERE Status = 0)
    BEGIN
        -- Select top N partitions for parallelism
        DECLARE @ParallelBatch TABLE (PartitionDate DATE);
        INSERT INTO @ParallelBatch (PartitionDate)
        SELECT TOP (@Parallelism) PartitionDate
        FROM @PartitionList
        WHERE Status = 0
        ORDER BY PartitionDate;

        DECLARE @p_date DATE;
        DECLARE part_cursor CURSOR FOR SELECT PartitionDate FROM @ParallelBatch;
        OPEN part_cursor;
        FETCH NEXT FROM part_cursor INTO @p_date;

        WHILE @@FETCH_STATUS = 0
        BEGIN
            DECLARE @sql NVARCHAR(MAX);

            SET @sql = '
                DECLARE @LastID BIGINT = 0;
                DECLARE @RowsInserted INT = 1;
                WHILE @RowsInserted > 0
                BEGIN
                    INSERT INTO ' + @StageTable + '
                    SELECT TOP (' + CAST(@BatchSize AS VARCHAR) + ') *
                    FROM ' + @SourceTable + '
                    WHERE CAST(' + @PartitionColumn + ' AS DATE) = ''' + CAST(@p_date AS VARCHAR) + '''
                      AND report_id > @LastID
                    ORDER BY report_id;

                    SET @RowsInserted = @@ROWCOUNT;
                    SELECT @LastID = MAX(report_id) FROM ' + @StageTable + ';
                END

                -- SWITCH partition
                DECLARE @partition INT;
                SELECT @partition = $PARTITION.pf_' + @ShadowTable + '(''' + CAST(@p_date AS VARCHAR) + ''');
                ALTER TABLE ' + @StageTable + ' SWITCH TO ' + @ShadowTable + ' PARTITION @partition;
                TRUNCATE TABLE ' + @StageTable + ';
            ';
            EXEC(@sql);

            -- Mark partition done
            UPDATE @PartitionList SET Status = 1 WHERE PartitionDate = @p_date;

            FETCH NEXT FROM part_cursor INTO @p_date;
        END
        CLOSE part_cursor;
        DEALLOCATE part_cursor;
    END

    ----------------------------------------------------------------
    -- STEP 7: Apply delta changes
    ----------------------------------------------------------------
    SET @DeltaRows = 1;
    WHILE @DeltaRows > 0
    BEGIN
        EXEC('
            INSERT INTO ' + @ShadowTable + '
            SELECT *
            FROM ' + @SourceTable + ' S
            WHERE NOT EXISTS (
                SELECT 1 FROM ' + @ShadowTable + ' T
                WHERE T.report_id = S.report_id
            )');
        SET @DeltaRows = @@ROWCOUNT;
    END

    ----------------------------------------------------------------
    -- STEP 8: Recreate nonclustered indexes dynamically
    ----------------------------------------------------------------
    SET @IDX_SQL = '';
    SELECT @IDX_SQL = STRING_AGG(
        'CREATE INDEX ' + i.name + '_shadow ON ' + @ShadowTable + '(' +
        STRING_AGG(c.name, ',') WITHIN GROUP (ORDER BY ic.key_ordinal) + ');', CHAR(13)
    )
    FROM sys.indexes i
    JOIN sys.index_columns ic
        ON i.object_id = ic.object_id AND i.index_id = ic.index_id
    JOIN sys.columns c
        ON ic.object_id = c.object_id AND ic.column_id = c.column_id
    WHERE i.object_id = OBJECT_ID(@SourceTable)
    AND i.type_desc='NONCLUSTERED';

    EXEC(@IDX_SQL);

    ----------------------------------------------------------------
    -- STEP 9: Final swap
    ----------------------------------------------------------------
    EXEC sp_rename @SourceTable, @SourceTable + '_old';
    EXEC sp_rename @ShadowTable, @SourceTable;

END
GO
