STEP 3 — Identify Partition Column
SQL
Copy code
SELECT c.name AS partition_column
FROM sys.tables t
JOIN sys.indexes i ON t.object_id=i.object_id
JOIN sys.index_columns ic ON i.object_id=ic.object_id AND i.index_id=ic.index_id
JOIN sys.columns c ON ic.object_id=c.object_id AND ic.column_id=c.column_id
WHERE t.name='cff_report'
AND ic.partition_ordinal=1
Example
Copy code

report_date
STEP 4 — Generate Table DDL Dynamically
SQL
Copy code
SELECT 
'[' + c.name + '] ' +
TYPE_NAME(c.user_type_id) +
CASE 
WHEN c.max_length = -1 THEN '(MAX)'
WHEN c.max_length > 0 AND TYPE_NAME(c.user_type_id) IN ('varchar','nvarchar','char')
THEN '(' + CAST(c.max_length AS VARCHAR) + ')'
ELSE ''
END +
CASE WHEN c.is_nullable=1 THEN ' NULL' ELSE ' NOT NULL' END
AS column_definition
FROM sys.columns c
WHERE c.object_id=OBJECT_ID('dbo.cff_report')
ORDER BY column_id
