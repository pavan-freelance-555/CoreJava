DECLARE @partitionColumn SYSNAME;
DECLARE @sql NVARCHAR(MAX);

SELECT @partitionColumn = c.name
FROM sys.tables t
JOIN sys.indexes i ON t.object_id = i.object_id
JOIN sys.index_columns ic ON i.object_id = ic.object_id AND i.index_id = ic.index_id
JOIN sys.columns c ON ic.object_id = c.object_id AND ic.column_id = c.column_id
WHERE t.name = 'cff_report'
AND ic.partition_ordinal = 1;

SET @sql = '
SELECT ' + QUOTENAME(@partitionColumn) + ', COUNT(*) AS row_count
FROM dbo.cff_report
GROUP BY ' + QUOTENAME(@partitionColumn) + '
ORDER BY ' + QUOTENAME(@partitionColumn);

EXEC sp_executesql @sql;