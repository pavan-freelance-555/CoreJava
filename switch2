2. INSERT single partition data
3. DROP old constraint
4. ADD dynamic constraint (this step)
5. SWITCH



Below is a production-ready single script that:
Detects all distinct partition values (report_date)
Loads one partition at a time
Validates data before SWITCH
Dynamically finds partition number
Performs safe SWITCH
Never mixes partitions (fixes your exact error)
✅ Full Dynamic Partition SWITCH Script
SQL
SET NOCOUNT ON;

DECLARE 
    @table_name SYSNAME = 'dbo.cff_report',
    @stage_table SYSNAME = 'dbo.cff_report_stage',
    @target_table SYSNAME = 'dbo.cff_report_partitioned',
    @partition_function SYSNAME = 'pf_report_date',
    @partition_date DATE,
    @sql NVARCHAR(MAX),
    @partition_number INT;

------------------------------------------------------------
-- STEP 1: Get all distinct partition values
------------------------------------------------------------
DECLARE partition_cursor CURSOR FOR
SELECT DISTINCT CAST(report_date AS DATE)
FROM dbo.cff_report
ORDER BY 1;

OPEN partition_cursor;
FETCH NEXT FROM partition_cursor INTO @partition_date;

WHILE @@FETCH_STATUS = 0
BEGIN
    PRINT 'Processing Partition Date: ' + CAST(@partition_date AS VARCHAR);

    ------------------------------------------------------------
    -- STEP 2: Clean stage table
    ------------------------------------------------------------
    SET @sql = 'TRUNCATE TABLE ' + @stage_table;
    EXEC(@sql);

    ------------------------------------------------------------
    -- STEP 3: Load ONLY ONE partition data
    ------------------------------------------------------------
    SET @sql = '
        INSERT INTO ' + @stage_table + '
        SELECT *
        FROM ' + @table_name + '
        WHERE CAST(report_date AS DATE) = @dt';

    EXEC sp_executesql 
        @sql,
        N'@dt DATE',
        @dt = @partition_date;

    ------------------------------------------------------------
    -- STEP 4: VALIDATION (critical)
    ------------------------------------------------------------
    IF (SELECT COUNT(DISTINCT CAST(report_date AS DATE)) FROM dbo.cff_report_stage) > 1
    BEGIN
        THROW 50000, 'Stage table has multiple partition values. Aborting.', 1;
    END

    ------------------------------------------------------------
    -- STEP 5: Get partition number dynamically
    ------------------------------------------------------------
    SET @sql = '
        SELECT @p = $PARTITION.' + @partition_function + '(@dt)';

    EXEC sp_executesql 
        @sql,
        N'@dt DATE, @p INT OUTPUT',
        @dt = @partition_date,
        @p = @partition_number OUTPUT;

    PRINT 'Switching to Partition: ' + CAST(@partition_number AS VARCHAR);

    ------------------------------------------------------------
    -- STEP 6: SWITCH
    ------------------------------------------------------------
    SET @sql = '
        ALTER TABLE ' + @stage_table + '
        SWITCH TO ' + @target_table + ' PARTITION ' + CAST(@partition_number AS VARCHAR);

    EXEC(@sql);

    ------------------------------------------------------------
    -- STEP 7: Next partition
    ------------------------------------------------------------
    FETCH NEXT FROM partition_cursor INTO @partition_date;
END

CLOSE partition_cursor;
DEALLOCATE partition_cursor;
